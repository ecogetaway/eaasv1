# Lambda environment variables (set via SAM template.yaml or AWS Console)
# Copy these to your samconfig.toml parameter_overrides or Lambda config

NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/eaas
JWT_SECRET=your_jwt_secret_min_32_chars
FRONTEND_URL=https://eaasv1.netlify.app
AWS_REGION=ap-south-1

# Optional — AWS services
AWS_S3_BUCKET=eaas-ticket-attachments
AWS_IOT_ENDPOINT=xxxxx-ats.iot.ap-south-1.amazonaws.com
DYNAMODB_TABLE=eaas-energy-readings
