NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eaas_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
UPLOAD_DIR=./uploads
FRONTEND_URL=https://ecogetaway.github.io

# ─── AWS Configuration ──────────────────────────────────────────────────────
# Region: ap-south-1 (Mumbai) for Indian customers
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 Bucket for ticket attachments and bill PDFs
# Create bucket: aws s3 mb s3://eaas-ticket-attachments --region ap-south-1
AWS_S3_BUCKET=eaas-ticket-attachments

# Presigned URL expiry (seconds) — 15 minutes for uploads
AWS_S3_PRESIGNED_URL_EXPIRY=900
