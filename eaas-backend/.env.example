NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eaas_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
UPLOAD_DIR=./uploads
FRONTEND_URL=https://ecogetaway.github.io

# ─── AWS Configuration ──────────────────────────────────────────────────────
# Region: ap-south-1 (Mumbai) — closest to Indian customers
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ─── Amazon S3 ───────────────────────────────────────────────────────────────
# Bucket for ticket attachments and bill PDFs
# Setup: aws s3 mb s3://eaas-ticket-attachments --region ap-south-1
AWS_S3_BUCKET=eaas-ticket-attachments
# Presigned URL expiry (seconds) — 15 minutes for uploads
AWS_S3_PRESIGNED_URL_EXPIRY=900

# ─── AWS IoT Core ────────────────────────────────────────────────────────────
# Device data endpoint — get via: aws iot describe-endpoint --endpoint-type iot:Data-ATS
# Format: xxxxxxxxxx-ats.iot.ap-south-1.amazonaws.com
AWS_IOT_ENDPOINT=your_iot_endpoint-ats.iot.ap-south-1.amazonaws.com

# ─── Amazon DynamoDB ─────────────────────────────────────────────────────────
# Table for high-frequency energy readings (hot path)
# Setup: aws dynamodb create-table --cli-input-json file://aws/dynamodb-table.json
DYNAMODB_TABLE=eaas-energy-readings
